{
  "name": "vrebaj-popust",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3191",
    "build": "next build --webpack",
    "postinstall": "prisma generate",
    "clean:build": "rm -rf node_modules && pnpm install && pnpm run build",
    "start": "next start",
    "cf:build": "DATABASE_URL=\"file:./local.db\" opennextjs-cloudflare build",
    "cf:preview": "DATABASE_URL=\"file:./local.db\" opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "DATABASE_URL=\"file:./local.db\" opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scrape": "npx tsx src/scraper/index.ts",
    "scrape:djak": "npx tsx src/scraper/stores/djaksport.ts",
    "scrape:planeta": "npx tsx src/scraper/stores/planeta.ts",
    "scrape:details": "npx tsx src/scraper/detail-scraper.ts",
    "scrape:details:djak": "npx tsx src/scraper/detail-scraper.ts djaksport",
    "scrape:intersport": "npx tsx src/scraper/stores/intersport.ts",
    "scrape:trefsport": "npx tsx src/scraper/stores/trefsport.ts",
    "scrape:health-check": "npx tsx src/scraper/health-check.ts"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.562.0",
    "next": "16.2.7",
    "prisma": "^6.19.2",
    "puppeteer": "^24.35.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  }
}
