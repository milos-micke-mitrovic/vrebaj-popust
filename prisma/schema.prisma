generator client {
  provider        = "prisma-client-js"
  // driverAdapters lets Prisma run on the Cloudflare D1 adapter at the edge.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE (Postgres -> SQLite/D1 migration):
// - Enums don't exist in SQLite -> `store`/`gender` are plain String (values are
//   still constrained in app code via the Store/Gender types).
// - Array columns don't exist in SQLite -> `sizes`/`categories`/`errors` are stored
//   as JSON-encoded TEXT (e.g. '["42","43"]'). They're (de)serialized centrally in
//   src/lib/deals.ts (convertDeal) and src/scraper/db-writer.ts, so the app-level
//   Deal type keeps `string[]`. Array filters use SQLite json_each via raw SQL.
// - DateTimes are written as ISO-8601 TEXT by the D1 adapter.

model Deal {
  id              String   @id
  store           String
  name            String
  brand           String?
  originalPrice   Int
  salePrice       Int
  discountPercent Int
  url             String   @unique
  imageUrl        String?

  // Detail scraper fields
  sizes           String   @default("[]") // JSON array of strings
  description     String?
  detailImageUrl  String?
  categories      String   @default("[]") // JSON array of category paths
  gender          String   @default("unisex")

  // Timestamps
  scrapedAt        DateTime  @default(now())
  detailsScrapedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([store])
  @@index([gender])
  @@index([discountPercent])
  @@index([brand])
  @@index([salePrice])
}

model ScrapeRun {
  id            String    @id @default(cuid())
  store         String
  totalScraped  Int
  filteredCount Int
  errors        String    @default("[]") // JSON array of strings
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
